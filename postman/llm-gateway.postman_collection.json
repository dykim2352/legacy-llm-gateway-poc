            "description": "Spring Boot legacy-mock-service를 직접 호출해 ERP 주문 mock 데이터를 확인합니다."
          }
        },
        {
          "name": "Direct Legacy Service - Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{LEGACY_URL}}/actuator/health",
            "description": "Spring Boot legacy-mock-service가 실행 중인지 확인합니다."
          }
        }
      ]
    },
    {
      "name": "Admin API",
      "item": [
        {
          "name": "Get Audit Logs",
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{ADMIN_TOKEN}}",
                "type": "string"
              }
            ]
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{BASE_URL}}/api/v1/admin/audit-logs",
            "description": "ADMIN 권한으로 PostgreSQL에 저장된 감사 로그를 조회합니다."
          }
        },
        {
          "name": "Access Denied - USER tries Admin API",
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{TOKEN}}",
                "type": "string"
              }
            ]
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{BASE_URL}}/api/v1/admin/audit-logs",
            "description": "USER 권한으로 관리자 API를 호출했을 때 접근이 거부되는지 확인합니다. 이 실패도 감사 로그에 기록됩니다.\n\n예상 결과:\n- `403 Forbidden`"
          }
        }
      ]
    }
  ]
}
